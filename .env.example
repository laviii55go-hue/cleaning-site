# 収益化・SEOの環境変数
# 本番用は .env または Vercel の Environment Variables に設定

# ===== サイトURL（必須：サイトマップ・canonical・robots.txt で使用） =====
# 本番の絶対URL（例: https://cleaning-site-xxx.vercel.app）
PUBLIC_SITE_URL=

# ===== Google AdSense =====
# 有効化する場合 'true' を設定
PUBLIC_ADSENSE_ENABLED=true

# AdSense 発行者ID（ca-pub-xxxxxxxx の形式）
PUBLIC_ADSENSE_CLIENT=ca-pub-3965931075265436
# 上記は設定済み。スロットIDを追加すると広告が表示されます。

# 広告ユニットのスロットID（各サイズで作成した広告のID）
PUBLIC_ADSENSE_SLOT_SMALL=
PUBLIC_ADSENSE_SLOT_MEDIUM=
PUBLIC_ADSENSE_SLOT_BANNER=

# ===== 楽天アフィリエイト =====
# 楽天モーションウィジェット用アフィリエイトID（例: 36aa5de7.f708acbb.36aa5de8.4921b4af）
PUBLIC_RAKUTEN_AFFILIATE_ID=
