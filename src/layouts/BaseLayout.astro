---
import { adsense } from '../config/monetization';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  breadcrumbs?: BreadcrumbItem[];
  image?: string;
}

const { title, description = 'お掃除の方法や豆知識をまとめた総合サイト。キッチン、浴室、リビングなど各場所別、油汚れ・水垢・カビなど汚れ別、季節ごとのお掃除情報をお届けします。', breadcrumbs, image } = Astro.props;

const siteUrl = String(Astro.site ?? 'https://example.com').replace(/\/$/, '');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const fullTitle = `${title} | お掃除ナビ`;
const ogImage = image
  ? (image.startsWith('http') ? image : new URL(image.startsWith('/') ? image : `/${image}`, siteUrl).href)
  : new URL('/ogp.png', siteUrl).href;

const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const isProd = import.meta.env.PROD;
---
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href={new URL('sitemap-index.xml', siteUrl).href} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {adsense.clientId && (
      <meta name="google-adsense-account" content={adsense.clientId} />
    )}
    <title>{fullTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700&display=swap" rel="stylesheet" />
    {adsense.enabled && adsense.clientId && (
      <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsense.clientId}`} crossorigin="anonymous"></script>
    )}
    {isProd && gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body>
    <header class="header">
      <div class="header-inner">
        <a href="/" class="logo">お掃除ナビ</a>
        <nav class="nav">
          <a href="/place/">場所で探す</a>
          <a href="/stain/">汚れで探す</a>
          <a href="/season/">季節で探す</a>
          <a href="/basic/">共通知識</a>
          <a href="/blog/">ブログ</a>
        </nav>
        <button class="menu-btn" aria-label="メニュー" type="button">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
      <nav class="nav-mobile" aria-hidden="true">
        <a href="/place/">場所で探す</a>
        <a href="/stain/">汚れで探す</a>
        <a href="/season/">季節で探す</a>
        <a href="/basic/">共通知識</a>
        <a href="/blog/">ブログ</a>
      </nav>
    </header>
    <main class="main">
      {breadcrumbs && breadcrumbs.length > 0 && (
        <div class="breadcrumbs-wrap">
          <div class="breadcrumbs-container">
            <Breadcrumbs items={breadcrumbs} />
          </div>
        </div>
      )}
      <slot />
    </main>
    <div class="rakuten-footer">
      <div class="rakuten-footer-inner">
        <p class="rakuten-widget-label">楽天市場で関連商品を探す</p>
        <p class="rakuten-disclosure"><small>当サイトは楽天アフィリエイトを利用しています。リンクから購入すると、当サイトに紹介料が入る場合があります。</small></p>
        <div class="rakuten-widget-container">
      <script is:inline type="text/javascript">
        rakuten_design="slide";rakuten_affiliateId="36aa5de7.f708acbb.36aa5de8.4921b4af";rakuten_items="ranking";rakuten_genreId="558944";rakuten_size="600x200";rakuten_target="_blank";rakuten_theme="gray";rakuten_border="off";rakuten_auto_mode="on";rakuten_genre_title="off";rakuten_recommend="on";rakuten_ts="1773218495829";
      </script>
      <script type="text/javascript" src="https://xml.affiliate.rakuten.co.jp/widget/js/rakuten_widget.js?20230106"></script>
        </div>
      </div>
    </div>
    <footer class="footer">
      <div class="footer-inner">
        <p class="copyright">© 2025 お掃除ナビ</p>
        <h2 class="footer-sitemap-title">サイトマップ</h2>
        <nav class="footer-nav" aria-label="サイトマップ">
          <a href="/">ホーム</a>
          <a href="/place/">場所で探す</a>
          <a href="/stain/">汚れで探す</a>
          <a href="/season/">季節で探す</a>
          <a href="/basic/">共通知識</a>
          <a href="/blog/">ブログ一覧</a>
        </nav>
      </div>
    </footer>
    <script>
      document.querySelector('.menu-btn')?.addEventListener('click', () => {
        const nav = document.querySelector('.nav-mobile');
        nav?.setAttribute('aria-hidden', nav.getAttribute('aria-hidden') === 'false' ? 'true' : 'false');
        document.body.classList.toggle('menu-open');
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    /* モダン・ミニマル：深い藍・紺テーマ */
    --color-primary: #2c3e76;
    --color-primary-light: #5b7cba;
    --color-primary-dark: #1e2d5c;
    --color-bg: #fafbfc;
    --color-surface: #ffffff;
    --color-text: #2c3e76;
    --color-text-muted: #5a6b7a;
    --color-border: #e2e8ee;
    --font-sans: 'Noto Sans JP', sans-serif;
    --radius: 4px;
    --shadow: 0 1px 3px rgba(44, 62, 118, 0.06);
    --shadow-hover: 0 4px 12px rgba(44, 62, 118, 0.1);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-sans);
    color: var(--color-text);
    background: var(--color-bg);
    margin: 0;
    line-height: 1.8;
  }

  a {
    color: var(--color-primary);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  img {
    max-width: 100%;
    height: auto;
  }
</style>

<style>
  .header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary) !important;
    text-decoration: none !important;
  }

  .logo:hover {
    color: var(--color-primary-dark) !important;
  }

  .nav {
    display: none;
    gap: 1.5rem;
  }

  .nav a {
    color: var(--color-text);
    font-size: 0.9rem;
  }

  .menu-btn {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .menu-btn span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text);
  }

  .nav-mobile {
    display: none;
    flex-direction: column;
    max-height: 0;
    overflow: hidden;
    padding: 1rem 1.5rem;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
  }

  body.menu-open .nav-mobile {
    display: flex;
    max-height: 300px;
  }

  .nav-mobile a {
    padding: 0.75rem 0;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
  }

  .main {
    min-height: calc(100vh - 180px);
    padding: 2rem 1.5rem;
  }

  .breadcrumbs-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .breadcrumbs-container {
    margin-bottom: 0.5rem;
  }

  .rakuten-footer {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem 2rem;
    text-align: center;
  }

  .rakuten-footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .rakuten-widget-container {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .rakuten-footer .rakuten-widget-label {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0 0 0.5rem 0;
  }

  .rakuten-footer .rakuten-disclosure {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem 0;
    line-height: 1.5;
  }

  .footer {
    background: var(--color-primary);
    color: white;
    padding: 2rem 1.5rem;
    margin-top: 3rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }

  .footer-sitemap-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 1rem 0 0.5rem 0;
    opacity: 0.85;
  }

  .footer-nav {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .footer-nav a {
    color: rgba(255, 255, 255, 0.9);
  }

  .copyright {
    margin: 0;
    font-size: 0.875rem;
    opacity: 0.9;
  }

  @media (min-width: 768px) {
    .nav {
      display: flex;
    }

    .menu-btn {
      display: none;
    }

    .nav-mobile {
      display: none !important;
    }
  }
</style>
