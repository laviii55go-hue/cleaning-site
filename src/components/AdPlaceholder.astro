---
import { adsense } from '../config/monetization';

interface Props {
  size?: 'small' | 'medium' | 'banner';
  label?: string;
}

const { size = 'medium', label = '広告スペース' } = Astro.props;

const sizeStyles = {
  small: { width: 300, height: 250 },
  medium: { width: 336, height: 280 },
  banner: { width: 728, height: 90 },
};

const slotId = adsense.slots[size];
const showAd = adsense.enabled && adsense.clientId && slotId;
---
{showAd ? (
  <div class="ad-container" data-size={size}>
    <ins
      class="adsbygoogle"
      style={`display:block; min-height:${sizeStyles[size].height}px`}
      data-ad-client={adsense.clientId}
      data-ad-slot={slotId}
      data-ad-format="auto"
      data-full-width-responsive="true"
    />
    <script is:inline>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
) : (
  <div class="ad-placeholder" data-size={size}>
    <span class="ad-label">{label}</span>
    <span class="ad-size">{sizeStyles[size].width}×{sizeStyles[size].height}</span>
  </div>
)}

<style>
  .ad-container {
    margin: 2rem 0;
    min-height: 90px;
  }

  .ad-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--color-border);
    border: 1px dashed var(--color-text-muted);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin: 2rem 0;
    min-height: 120px;
  }

  .ad-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .ad-size {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  [data-size="small"] {
    max-width: 300px;
    margin-left: auto;
    margin-right: auto;
  }

  [data-size="banner"] .ad-placeholder {
    min-height: 90px;
  }
</style>
