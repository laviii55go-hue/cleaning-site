---
interface Props {
  size?: 'small' | 'medium' | 'banner';
  label?: string;
}

const { size = 'medium', label = '広告スペース' } = Astro.props;

const sizeStyles = {
  small: '300x250',
  medium: '336x280',
  banner: '728x90',
};
---
<div class="ad-placeholder" data-size={size}>
  <span class="ad-label">{label}</span>
  <span class="ad-size">{sizeStyles[size]}</span>
</div>

<style>
  .ad-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--color-border);
    border: 1px dashed var(--color-text-muted);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin: 2rem 0;
    min-height: 120px;
  }

  .ad-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .ad-size {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  [data-size="small"] {
    max-width: 300px;
    margin-left: auto;
    margin-right: auto;
  }

  [data-size="banner"] {
    min-height: 90px;
  }
</style>
