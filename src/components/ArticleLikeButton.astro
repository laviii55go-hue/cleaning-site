---
interface Props {
  slug: string;
}

const { slug } = Astro.props;
---

<section class="like" aria-label="この記事の参考度">
  <button
    type="button"
    class="like-button"
    data-like-slug={slug}
    aria-pressed="false"
  >
    <span class="like-label">なるほど！</span>
    <span class="like-count" data-like-count>0</span>
  </button>
  <p class="like-note">※1ブラウザにつき1回までカウントされます</p>
  <p class="like-status" role="status" aria-live="polite"></p>
</section>

<script is:inline>
  console.log('[なるほど] script 読み込み完了');
  window.addEventListener('load', function () {
    console.log('[なるほど] load 発火');
    var likeSection = document.querySelector('section.like');
    if (!likeSection) {
      console.warn('[なるほど] section.like が見つかりません');
      return;
    }
    var btn = likeSection.querySelector('.like-button');
    var countEl = likeSection.querySelector('[data-like-count]');
    var statusEl = likeSection.querySelector('.like-status');
    var slug = btn ? btn.getAttribute('data-like-slug') : null;

    function setStatus(msg) {
      if (statusEl) { statusEl.textContent = msg; statusEl.className = 'like-status is-visible'; }
    }

    if (!btn || !countEl || !slug) {
      setStatus('ボタンの準備に失敗しました');
      console.warn('[なるほど] ボタン・カウント・slug のいずれかが見つかりません', { btn: !!btn, countEl: !!countEl, slug: slug });
      return;
    }
    if (!window.firebase) {
      setStatus('Firebaseの読み込みに失敗しました（apiKey等を確認してください）');
      console.warn('[なるほど] window.firebase がありません');
      return;
    }
    if (!window.firebase.firestore) {
      setStatus('Firestoreの読み込みに失敗しました');
      console.warn('[なるほど] window.firebase.firestore がありません');
      return;
    }

    var db = window.firebase.firestore();
    var docRef = db.collection('articleLikes').doc(slug);
    var storageKey = 'article-like:' + slug;

    docRef.get().then(function (snap) {
      if (snap.exists) {
        var data = snap.data() || {};
        var count = typeof data.count === 'number' ? data.count : 0;
        countEl.textContent = String(count);
      }
      if (localStorage.getItem(storageKey) === 'liked') {
        btn.classList.add('is-liked');
        btn.setAttribute('aria-pressed', 'true');
      }
    }).catch(function (e) {
      console.warn('[なるほど] 初期読み込みエラー', e);
      setStatus('カウントの取得に失敗しました');
    });

    btn.addEventListener('click', function () {
      if (localStorage.getItem(storageKey) === 'liked') return;
      var self = btn;
      (async function () {
        try {
          var now = window.firebase.firestore.FieldValue.serverTimestamp();
          await docRef.set(
            {
              slug: slug,
              count: window.firebase.firestore.FieldValue.increment(1),
              updatedAt: now,
            },
            { merge: true }
          );
          var snap = await docRef.get();
          var data = snap.data() || {};
          var count = typeof data.count === 'number' ? data.count : 0;
          countEl.textContent = String(count);
          localStorage.setItem(storageKey, 'liked');
          self.classList.add('is-liked');
          self.setAttribute('aria-pressed', 'true');
        } catch (e) {
          console.error('[なるほど] 送信エラー', e);
          setStatus('送信に失敗しました: ' + (e && e.message ? e.message : '不明'));
        }
      })();
    });
  });
</script>

<style>
  .like {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .like-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    cursor: pointer;
    font-size: 0.9rem;
    color: var(--color-text);
    transition: background 0.2s, border-color 0.2s, transform 0.05s;
  }

  .like-button:hover {
    border-color: var(--color-primary-light);
    background: var(--color-bg);
  }

  .like-button:active {
    transform: scale(0.98);
  }

  .like-button.is-liked {
    border-color: var(--color-primary);
    background: rgba(44, 62, 118, 0.06);
  }

  .like-label {
    font-weight: 600;
  }

  .like-count {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .like-note {
    margin: 0.5rem 0 0 0;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .like-status {
    margin: 0.5rem 0 0 0;
    font-size: 0.8rem;
    min-height: 1.25em;
    color: var(--color-primary);
  }

  .like-status.is-visible {
    color: #c0392b;
  }
</style>

