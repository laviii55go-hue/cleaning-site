---
---

<section class="hero-outer">
  <div class="hero-inner">
    <!-- 左カラム：テキスト -->
    <div class="hero-left">
      <div class="hero-badge-row">
        <span class="hero-badge">
          <span class="hero-badge-dot" />
          毎週更新
        </span>
        <span class="hero-badge-note">100本以上のお掃除記事を掲載</span>
      </div>

      <h1 class="hero-heading">
        お掃除で
        <span class="hero-highlight-wrap">
          <span class="hero-highlight-text">もう悩まない。</span>
          <span class="hero-highlight-underline" />
        </span>
      </h1>

      <p class="hero-copy">
        場所別・汚れ別・季節別に、お掃除のコツをやさしく解説。<br />
        あなたのお掃除の「困った」を、今すぐ解決できる記事をそろえています。
      </p>

      <div class="hero-cta-row">
        <a href="/place/" class="hero-cta-primary">
          掃除方法を探す
          <span class="hero-cta-icon" aria-hidden="true">→</span>
        </a>
        <a href="/basic/" class="hero-cta-secondary">
          基本を学ぶ
        </a>
        <a href="/#new-articles" class="hero-cta-secondary">
          新着記事
        </a>
      </div>
    </div>

    <!-- 右カラム：お悩みワードの吹き出し -->
    <div class="hero-right" aria-hidden="true">
      <div class="hero-orbit">
        <div class="hero-orbit-core">
          <span class="hero-orbit-icon">✨</span>
        </div>
      </div>

      <div class="hero-bubble bubble-1">
        <span class="hero-bubble-emoji">😥</span> カビが取れない…
      </div>
      <div class="hero-bubble bubble-2">
        <span class="hero-bubble-emoji">🍳</span> 換気扇の油汚れ
      </div>
      <div class="hero-bubble bubble-3">
        <span class="hero-bubble-emoji">🫧</span> 排水口のヌメリ
      </div>
      <div class="hero-bubble bubble-4">
        <span class="hero-bubble-emoji">🌸</span> 花粉シーズンの掃除
      </div>
    </div>
  </div>
</section>

<style>
  .hero-outer {
    background: #ffffff;
    overflow: hidden;
    padding: 3.5rem 1.5rem 2.5rem;
  }

  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  .hero-left {
    max-width: 520px;
  }

  .hero-badge-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border-radius: 999px;
    background: rgba(16, 185, 129, 0.12);
    color: #047857;
    padding: 0.3rem 0.85rem;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .hero-badge-dot {
    display: inline-block;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background: #10b981;
  }

  .hero-badge-note {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .hero-heading {
    font-size: 2.1rem;
    line-height: 1.3;
    font-weight: 700;
    color: #111827;
    margin: 0 0 1.25rem 0;
    letter-spacing: 0.02em;
  }

  .hero-highlight-wrap {
    position: relative;
    display: inline-block;
    margin-left: 0.25rem;
  }

  .hero-highlight-text {
    position: relative;
    z-index: 1;
  }

  .hero-highlight-underline {
    position: absolute;
    left: 0;
    bottom: 0.15rem;
    width: 100%;
    height: 0.55rem;
    border-radius: 999px;
    background: rgba(252, 211, 77, 0.6);
    z-index: 0;
  }

  .hero-copy {
    margin: 0;
    margin-top: 0.75rem;
    font-size: 0.98rem;
    line-height: 1.9;
    color: var(--color-text-muted);
  }

  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  .hero-cta-primary,
  .hero-cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    border-radius: 0.6rem;
    padding: 0.7rem 1.6rem;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none !important;
    transition: background 0.2s, color 0.2s, box-shadow 0.2s, border-color 0.2s;
  }

  .hero-cta-primary {
    background: #111827;
    color: #ffffff !important;
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.18);
  }

  .hero-cta-primary:hover {
    background: #020617;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.28);
  }

  .hero-cta-secondary {
    border: 1px solid var(--color-border);
    color: var(--color-text);
    background: #ffffff;
  }

  .hero-cta-secondary:hover {
    background: var(--color-bg);
    border-color: var(--color-primary-light);
  }

  .hero-cta-icon {
    font-size: 0.9rem;
  }

  .hero-right {
    position: relative;
    min-height: 260px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-orbit {
    width: 230px;
    height: 230px;
    border-radius: 999px;
    background: radial-gradient(circle at 0% 0%, #e0f2fe, #ecfdf5 60%, #eff6ff 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.18);
  }

  .hero-orbit-core {
    width: 120px;
    height: 120px;
    border-radius: 999px;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 1px rgba(148, 163, 184, 0.3);
  }

  .hero-orbit-icon {
    font-size: 2.5rem;
  }

  .hero-bubble {
    position: absolute;
    background: #ffffff;
    border-radius: 0.9rem;
    padding: 0.5rem 0.9rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: #475569;
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.12);
    border: 1px solid rgba(148, 163, 184, 0.2);
    white-space: nowrap;
  }

  .hero-bubble-emoji {
    margin-right: 0.25rem;
  }

  .bubble-1 {
    top: 4%;
    left: 4%;
    animation: float1 3s ease-in-out infinite;
  }

  .bubble-2 {
    top: 16%;
    right: 0;
    animation: float2 3.5s ease-in-out 0.5s infinite;
  }

  .bubble-3 {
    bottom: 22%;
    left: 0;
    animation: float3 4s ease-in-out 1s infinite;
  }

  .bubble-4 {
    bottom: 4%;
    right: 4%;
    animation: float4 3.2s ease-in-out 1.5s infinite;
  }

  @keyframes float1 {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  @keyframes float2 {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  @keyframes float3 {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }

  @keyframes float4 {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }

  @media (min-width: 768px) {
    .hero-outer {
      padding-top: 4rem;
      padding-bottom: 3.5rem;
    }

    .hero-inner {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
      gap: 3.5rem;
    }

    .hero-heading {
      font-size: 2.4rem;
    }

    .hero-right {
      min-height: 320px;
    }

    .hero-orbit {
      width: 270px;
      height: 270px;
    }
  }

  @media (min-width: 1024px) {
    .hero-heading {
      font-size: 2.7rem;
    }

    .hero-right {
      min-height: 360px;
    }

    .hero-orbit {
      width: 300px;
      height: 300px;
    }
  }
</style>

