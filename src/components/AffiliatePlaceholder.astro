---
import { affiliate } from '../config/monetization';

interface Product {
  name: string;
  description?: string;
  url?: string;
  image?: string;
  price?: string;
}

interface Props {
  title?: string;
  products?: Product[];
  items?: number;
}

const { title = 'おすすめグッズ', products = [], items = 3 } = Astro.props;

const displayProducts = products.length > 0
  ? products
  : Array.from({ length: items }).map(() => ({
      name: '商品名（楽天アフィリエイト）',
      url: undefined,
      image: undefined,
      price: '¥---',
    }));
---
<section class="affiliate-section">
  <h3 class="affiliate-title">{title}</h3>
  {affiliate.disclosureRequired && (
    <p class="affiliate-disclosure">
      <small>当サイトは楽天アフィリエイトを利用しています。リンクから購入すると、当サイトに紹介料が入る場合があります。</small>
    </p>
  )}
  <div class="affiliate-list">
    {displayProducts.map((product) => (
      <div class="affiliate-card">
        <div class="affiliate-card-inner">
          <div class="affiliate-card-image">
            {product.url ? (
              <a href={product.url} target="_blank" rel="noopener noreferrer sponsored">
                {product.image ? (
                  <img src={product.image} alt={product.name} loading="lazy" />
                ) : (
                  <div class="affiliate-image-placeholder"></div>
                )}
              </a>
            ) : (
              product.image ? (
                <img src={product.image} alt={product.name} loading="lazy" />
              ) : (
                <div class="affiliate-image-placeholder"></div>
              )
            )}
          </div>
          <div class="affiliate-card-content">
            <p class="affiliate-card-name">{product.name}</p>
            {product.description && (
              <p class="affiliate-card-desc">{product.description}</p>
            )}
            {product.price && (
              <p class="affiliate-card-price">{product.price}</p>
            )}
            {product.url && (
              <a href={product.url} class="affiliate-card-btn" target="_blank" rel="noopener noreferrer sponsored">
                楽天で購入
              </a>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .affiliate-section {
    margin: 2rem 0;
  }

  .affiliate-title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
    color: var(--color-text);
  }

  .affiliate-disclosure {
    margin: 0 0 1rem 0;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .affiliate-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .affiliate-card {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-surface);
    overflow: hidden;
  }

  .affiliate-card-inner {
    display: flex;
    flex-direction: row;
    min-height: 120px;
  }

  .affiliate-card-image {
    flex-shrink: 0;
    width: 120px;
    min-height: 120px;
  }

  .affiliate-card-image img,
  .affiliate-card-image a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .affiliate-card-image img {
    object-fit: cover;
    aspect-ratio: 1;
  }

  .affiliate-image-placeholder {
    width: 100%;
    aspect-ratio: 1;
    background: var(--color-border);
  }

  .affiliate-card-content {
    flex: 1;
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-width: 0;
  }

  .affiliate-card-name {
    font-size: 0.9rem;
    font-weight: 600;
    margin: 0 0 0.25rem 0;
    color: var(--color-text);
    line-height: 1.4;
  }

  .affiliate-card-desc {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin: 0 0 0.5rem 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .affiliate-card-price {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0 0 0.5rem 0;
  }

  .affiliate-card-btn {
    display: inline-block;
    width: fit-content;
    padding: 0.4rem 1rem;
    background: #bf0000;
    color: white !important;
    font-size: 0.8rem;
    font-weight: 500;
    border-radius: 1rem;
    text-decoration: none !important;
    margin-top: auto;
    transition: opacity 0.2s;
  }

  .affiliate-card-btn:hover {
    opacity: 0.9;
  }

  @media (min-width: 480px) {
    .affiliate-card-image {
      width: 160px;
      min-height: 160px;
    }

    .affiliate-card-inner {
      min-height: 160px;
    }
  }

  @media (min-width: 640px) {
    .affiliate-card-image {
      width: 200px;
      min-height: 200px;
    }

    .affiliate-card-inner {
      min-height: 200px;
    }

    .affiliate-card-content {
      padding: 1rem 1.25rem;
    }

    .affiliate-card-name {
      font-size: 1rem;
    }

    .affiliate-card-desc {
      font-size: 0.8rem;
      -webkit-line-clamp: 4;
    }
  }
</style>
