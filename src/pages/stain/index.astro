---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const articlesBySlug = new Map<string, typeof allArticles[0]>();
for (const entry of allArticles) {
  if (entry.data.part === 1 && entry.data.stain && !articlesBySlug.has(entry.data.slug)) {
    articlesBySlug.set(entry.data.slug, entry);
  }
}

const stains = [
  { id: 'oil', name: '油汚れ', icon: '🛢️' },
  { id: 'water-scale', name: '水垢', icon: '💧' },
  { id: 'mold', name: 'カビ', icon: '🦠' },
  { id: 'dust', name: 'ホコリ', icon: '🌫️' },
  { id: 'stain', name: 'シミ・汚れ', icon: '🧴' },
];

const articlesByStain = new Map<string, typeof allArticles[0][]>();
for (const entry of articlesBySlug.values()) {
  const stain = entry.data.stain;
  if (stain) {
    if (!articlesByStain.has(stain)) articlesByStain.set(stain, []);
    articlesByStain.get(stain)!.push(entry);
  }
}
---

<BaseLayout title="汚れで探す" description="油汚れ、水垢、カビなど汚れ別のお掃除方法">
  <div class="container">
    <h1 class="page-title">汚れで探す</h1>
    <p class="page-desc">汚れの種類別のお掃除方法・豆知識をまとめています</p>

    <div class="stain-grid">
      {stains.map((stain) => {
        const articles = articlesByStain.get(stain.id) || [];
        return (
          <section class="stain-section">
            <h2 class="stain-name">
              <span class="stain-icon">{stain.icon}</span>
              {stain.name}
            </h2>
            {articles.length > 0 ? (
              <ul class="article-list">
                {articles.map((entry) => (
                  <li>
                    <a href={`/articles/${entry.data.slug}/1`}>{entry.data.title}</a>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="no-articles">記事はまだありません</p>
            )}
          </section>
        );
      })}
    </div>
  </div>
</BaseLayout>

<style>
  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  .page-title {
    font-size: 1.75rem;
    margin: 0 0 0.5rem 0;
  }

  .page-desc {
    color: var(--color-text-muted);
    margin: 0 0 2rem 0;
  }

  .stain-grid {
    display: grid;
    gap: 2rem;
  }

  .stain-section {
    background: var(--color-surface);
    padding: 1.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }

  .stain-name {
    font-size: 1.1rem;
    margin: 0 0 1rem 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .stain-icon {
    font-size: 1.5rem;
  }

  .article-list {
    margin: 0;
    padding-left: 1.25rem;
  }

  .article-list li {
    margin: 0.5rem 0;
  }

  .no-articles {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
</style>
