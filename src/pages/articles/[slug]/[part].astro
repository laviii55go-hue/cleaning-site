---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import ArticlePagination from '../../../components/ArticlePagination.astro';
import ArticleShare from '../../../components/ArticleShare.astro';
import AdPlaceholder from '../../../components/AdPlaceholder.astro';
import AffiliatePlaceholder from '../../../components/AffiliatePlaceholder.astro';
import ArticleLikeButton from '../../../components/ArticleLikeButton.astro';
import { getPlaceInfo, getStainInfo, getSeasonInfo, getPlaceUrl, getStainUrl, getSeasonUrl } from '../../../config/categories';

export async function getStaticPaths() {
  const allArticles = await getCollection('articles');
  return allArticles.map((entry) => ({
    params: { slug: entry.data.slug, part: String(entry.data.part) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { slug, part, totalParts, title, recommendedProducts } = entry.data;

// 関連記事（同じカテゴリの他の記事）
const allArticles = await getCollection('articles');
const part1Entries = allArticles.filter((e) => e.data.part === 1 && e.data.slug !== slug);
const relatedArticles = part1Entries
  .filter((e) => 
    (entry.data.place && e.data.place === entry.data.place) ||
    (entry.data.stain && e.data.stain === entry.data.stain) ||
    (entry.data.season && e.data.season === entry.data.season)
  )
  .slice(0, 3);
if (relatedArticles.length < 3) {
  relatedArticles.push(...part1Entries.filter((e) => !relatedArticles.includes(e)).slice(0, 3 - relatedArticles.length));
}

const siteUrl = String(Astro.site ?? 'https://example.com').replace(/\/$/, '');
const articleUrl = new URL(`/articles/${slug}/1`, siteUrl).href;
const currentPageUrl = new URL(`/articles/${slug}/${part}`, siteUrl).href;
const breadcrumbs = [
  { label: 'ホーム', href: '/' },
  { label: 'ブログ一覧', href: '/blog/' },
  { label: title, href: `/articles/${slug}/1` },
];

// JSON-LD Article（構造化データ）
const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: entry.data.description,
  datePublished: entry.data.pubDate.toISOString(),
  url: articleUrl,
  publisher: {
    '@type': 'Organization',
    name: 'お掃除ナビ',
    url: siteUrl,
  },
};
if (entry.data.updatedDate) {
  jsonLd.dateModified = entry.data.updatedDate.toISOString();
}
---

<BaseLayout
  title={title}
  description={entry.data.description}
  breadcrumbs={breadcrumbs}
  image={entry.data.image}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article class="article">
    <div class="container">
      <header class="article-header">
        <div class="article-meta">
          {entry.data.place && (() => {
            const info = getPlaceInfo(entry.data.place!);
            return info ? <a href={getPlaceUrl(entry.data.place!)} class="tag tag-link">{info.name}</a> : <span class="tag">{entry.data.place}</span>;
          })()}
          {entry.data.stain && (() => {
            const info = getStainInfo(entry.data.stain!);
            return info ? <a href={getStainUrl(entry.data.stain!)} class="tag tag-link">{info.name}</a> : <span class="tag">{entry.data.stain}</span>;
          })()}
          {entry.data.season && (() => {
            const info = getSeasonInfo(entry.data.season!);
            return info ? <a href={getSeasonUrl(entry.data.season!)} class="tag tag-link">{info.name}</a> : <span class="tag">{entry.data.season}</span>;
          })()}
          <span class="date">公開日：{entry.data.pubDate.toLocaleDateString('ja-JP')}</span>
          {entry.data.updatedDate && (
            <span class="date">最終更新：{entry.data.updatedDate.toLocaleDateString('ja-JP')}</span>
          )}
        </div>
        <h1 class="article-title">{title}</h1>
      </header>

      <div class="article-body">
        <Content />
      </div>

      {relatedArticles.length > 0 && (
        <p class="article-inline-related">
          あわせて読みたい：<a href={`/articles/${relatedArticles[0].data.slug}/1`}>{relatedArticles[0].data.title}</a>
        </p>
      )}

      {(part === 2 || part === 3) && (
        <AffiliatePlaceholder title="この作業で使えるおすすめグッズ" products={recommendedProducts} items={3} />
      )}

      <ArticlePagination slug={slug} currentPart={part} totalParts={totalParts} title={title} />

      <ArticleShare shareUrl={currentPageUrl} title={title} />

      <ArticleLikeButton slug={slug} title={title} />

      {/* 広告スペース336×280：現時点では非表示 */}
      {false && part === totalParts && (
        <AdPlaceholder size="medium" />
      )}

      {part === totalParts && relatedArticles.length > 0 && (
        <section class="related">
          <h2 class="related-title">関連記事</h2>
          <ul class="related-list">
            {relatedArticles.map((e) => (
              <li>
                <a href={`/articles/${e.data.slug}/1`}>{e.data.title}</a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    padding-bottom: 3rem;
  }

  .container {
    max-width: 720px;
    margin: 0 auto;
  }

  .article-header {
    margin-bottom: 2rem;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .tag {
    background: var(--color-primary);
    color: white;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.8rem;
  }

  .tag-link {
    text-decoration: none !important;
    color: white !important;
  }

  .tag-link:hover {
    opacity: 0.9;
  }

  .date {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .article-title {
    font-size: 1.5rem;
    margin: 0;
    line-height: 1.4;
  }

  .article-body {
    font-size: 1rem;
    line-height: 1.9;
  }

  .article-body :global(h2) {
    font-size: 1.1rem;
    margin: 2rem 0 1rem 0;
    padding: 0.6rem 1rem;
    background-color: var(--color-primary);
    color: white;
    border-radius: 4px;
    border: none;
  }

  .article-body :global(h3) {
    font-size: 1.05rem;
    margin: 1.5rem 0 0.75rem 0;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .article-body :global(p) {
    margin: 1rem 0;
  }

  .article-inline-related {
    margin: 1.5rem 0;
    padding: 0.75rem 1rem;
    background: var(--color-bg);
    border-left: 3px solid var(--color-primary);
    font-size: 0.9375rem;
    color: var(--color-text-muted);
  }

  .article-inline-related a {
    font-weight: 500;
  }

  .related {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .related-title {
    font-size: 1.1rem;
    margin: 0 0 1rem 0;
  }

  .related-list {
    margin: 0;
    padding-left: 1.25rem;
  }

  .related-list li {
    margin: 0.5rem 0;
  }
</style>
