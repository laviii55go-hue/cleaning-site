---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const siteTitle = '人気記事ランキング｜なるほどボタンが多い記事';
const siteDesc =
  '「なるほど！」ボタンが多く押された人気記事ランキング。実際に読者から支持されたお掃除記事をまとめています。';

const allArticles = await getCollection('articles');
const part1Entries = allArticles.filter((e) => e.data.part === 1);
const slugToTitle: Record<string, string> = {};
part1Entries.forEach((e) => {
  slugToTitle[e.data.slug] = e.data.title;
});
---

<BaseLayout
  title={siteTitle}
  description={siteDesc}
  breadcrumbs={[{ label: 'ホーム', href: '/' }, { label: '人気記事ランキング', href: '/likes/' }]}
>
  <div class="container">
    <div class="ranking-panel">
      <header class="ranking-header">
        <h1 class="page-title">人気記事ランキング</h1>
        <p class="page-desc">
          各記事の「なるほど！」ボタンの数にもとづいた人気記事ランキングです。<br />
          ランキングは一定時間ごとに更新されます。
        </p>
      </header>

      <ol class="ranking-list" id="likes-ranking" aria-live="polite">
        <li class="ranking-empty">読み込み中です…</li>
      </ol>
    </div>
  </div>
</BaseLayout>

<script is:inline set:html={`window.__ARTICLE_TITLES__=${JSON.stringify(slugToTitle)};`} />
<script is:inline>
  window.addEventListener('load', function () {
    var list = document.getElementById('likes-ranking');
    if (!list || !window.firebase || !window.firebase.firestore) {
      if (list) {
        list.innerHTML = '<li class="ranking-empty">ランキングを読み込めませんでした。</li>';
      }
      return;
    }
    if (!window.firebase.apps || window.firebase.apps.length === 0) {
      var cfg = window.__FIREBASE_CONFIG__;
      if (cfg && cfg.apiKey && cfg.projectId) {
        try { window.firebase.initializeApp(cfg); } catch (e) {}
      }
    }
    if (!window.firebase.apps || window.firebase.apps.length === 0) {
      if (list) {
        list.innerHTML = '<li class="ranking-empty">Firebaseの初期化に失敗しました。</li>';
      }
      return;
    }
    var db = window.firebase.firestore();
    db.collection('articleLikes')
      .orderBy('count', 'desc')
      .limit(20)
      .get()
      .then(function (snap) {
        if (snap.empty) {
          list.innerHTML = '<li class="ranking-empty">まだ「なるほど！」が押された記事はありません。</li>';
          return;
        }
        var titlesMap = window.__ARTICLE_TITLES__ || {};
        var items = [];
        var rank = 1;
        snap.forEach(function (doc) {
          var data = doc.data() || {};
          var slug = data.slug || doc.id;
          var count = typeof data.count === 'number' ? data.count : 0;
          var title = data.title || titlesMap[slug] || slug;
          var escapedTitle = title.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
          items.push(
            '<li class="ranking-item">' +
              '<span class="ranking-rank">' + rank + '</span>' +
              '<a href="/articles/' + slug + '/1" class="ranking-link">' + escapedTitle + '</a>' +
            '</li>'
          );
          rank++;
        });
        list.innerHTML = items.join('');
      })
      .catch(function () {
        list.innerHTML = '<li class="ranking-empty">ランキングを読み込めませんでした。</li>';
      });
  });
</script>

<style>
  .container {
    max-width: 720px;
    margin: 0 auto;
  }

  .ranking-panel {
    background: linear-gradient(165deg, #f8f9fc 0%, #ffffff 50%, #f4f6fb 100%);
    border: 1px solid rgba(44, 62, 118, 0.08);
    border-radius: 12px;
    box-shadow: 0 4px 24px rgba(44, 62, 118, 0.06), 0 1px 3px rgba(0, 0, 0, 0.04);
    padding: 2rem 1.75rem;
    margin-top: 0.5rem;
  }

  .ranking-header {
    margin-bottom: 1.75rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(44, 62, 118, 0.1);
  }

  .page-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    color: var(--color-primary-dark);
    letter-spacing: 0.02em;
  }

  .page-desc {
    color: var(--color-text-muted);
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.85;
  }

  .ranking-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ranking-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 1rem;
    margin-bottom: 0.5rem;
    background: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(44, 62, 118, 0.06);
    border-radius: 8px;
    transition: background 0.2s, border-color 0.2s, box-shadow 0.2s;
  }

  .ranking-item:hover {
    background: #fff;
    border-color: rgba(44, 62, 118, 0.12);
    box-shadow: 0 2px 8px rgba(44, 62, 118, 0.06);
  }

  .ranking-item:last-child {
    margin-bottom: 0;
  }

  .ranking-rank {
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: white;
    font-size: 0.8125rem;
    font-weight: 700;
    border-radius: 8px;
    box-shadow: 0 2px 6px rgba(44, 62, 118, 0.25);
  }

  .ranking-link {
    flex: 1;
    text-decoration: none !important;
    color: var(--color-text);
    font-weight: 500;
    font-size: 0.9375rem;
    line-height: 1.5;
    min-width: 0;
    transition: color 0.2s;
  }

  .ranking-link:hover {
    color: var(--color-primary);
  }

  .ranking-empty {
    padding: 1.25rem 1rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    text-align: center;
    background: rgba(255, 255, 255, 0.6);
    border-radius: 8px;
    border: 1px dashed rgba(44, 62, 118, 0.15);
  }
</style>

