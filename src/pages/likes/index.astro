---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const siteTitle = '人気記事ランキング｜なるほどボタンが多い記事';
const siteDesc =
  '「なるほど！」ボタンが多く押された人気記事ランキング。実際に読者から支持されたお掃除記事をまとめています。';

const allArticles = await getCollection('articles');
const part1Entries = allArticles.filter((e) => e.data.part === 1);
const slugToTitle: Record<string, string> = {};
part1Entries.forEach((e) => {
  slugToTitle[e.data.slug] = e.data.title;
});
---

<BaseLayout
  title={siteTitle}
  description={siteDesc}
  breadcrumbs={[{ label: 'ホーム', href: '/' }, { label: '人気記事ランキング', href: '/likes/' }]}
>
  <div class="container">
    <h1 class="page-title">人気記事ランキング</h1>
    <p class="page-desc">
      各記事の「なるほど！」ボタンの数にもとづいた人気記事ランキングです。<br />
      ランキングは一定時間ごとに更新されます。
    </p>

    <ol class="ranking-list" id="likes-ranking" aria-live="polite">
      <li class="ranking-empty">読み込み中です…</li>
    </ol>
  </div>
</BaseLayout>

<script is:inline set:html={`window.__ARTICLE_TITLES__=${JSON.stringify(slugToTitle)};`} />
<script is:inline>
  window.addEventListener('load', function () {
    var list = document.getElementById('likes-ranking');
    if (!list || !window.firebase || !window.firebase.firestore) {
      if (list) {
        list.innerHTML = '<li class="ranking-empty">ランキングを読み込めませんでした。</li>';
      }
      return;
    }
    if (!window.firebase.apps || window.firebase.apps.length === 0) {
      var cfg = window.__FIREBASE_CONFIG__;
      if (cfg && cfg.apiKey && cfg.projectId) {
        try { window.firebase.initializeApp(cfg); } catch (e) {}
      }
    }
    if (!window.firebase.apps || window.firebase.apps.length === 0) {
      if (list) {
        list.innerHTML = '<li class="ranking-empty">Firebaseの初期化に失敗しました。</li>';
      }
      return;
    }
    var db = window.firebase.firestore();
    db.collection('articleLikes')
      .orderBy('count', 'desc')
      .limit(20)
      .get()
      .then(function (snap) {
        if (snap.empty) {
          list.innerHTML = '<li class="ranking-empty">まだ「なるほど！」が押された記事はありません。</li>';
          return;
        }
        var titlesMap = window.__ARTICLE_TITLES__ || {};
        var items = [];
        var rank = 1;
        snap.forEach(function (doc) {
          var data = doc.data() || {};
          var slug = data.slug || doc.id;
          var count = typeof data.count === 'number' ? data.count : 0;
          var title = data.title || titlesMap[slug] || slug;
          var escapedTitle = title.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
          items.push(
            '<li class="ranking-item">' +
              '<span class="ranking-rank">' + rank + '</span>' +
              '<a href="/articles/' + slug + '/1" class="ranking-link">' + escapedTitle + '</a>' +
              '<span class="ranking-count">' + count + ' <span class="ranking-count-unit">なるほど</span></span>' +
            '</li>'
          );
          rank++;
        });
        list.innerHTML = items.join('');
      })
      .catch(function () {
        list.innerHTML = '<li class="ranking-empty">ランキングを読み込めませんでした。</li>';
      });
  });
</script>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
  }

  .page-title {
    font-size: 1.75rem;
    margin: 0 0 0.5rem 0;
  }

  .page-desc {
    color: var(--color-text-muted);
    margin: 0 0 2rem 0;
    font-size: 0.95rem;
    line-height: 1.9;
  }

  .ranking-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ranking-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    margin-bottom: 0.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .ranking-rank {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: white;
    font-size: 0.875rem;
    font-weight: 700;
    border-radius: 4px;
  }

  .ranking-link {
    flex: 1;
    text-decoration: none !important;
    color: var(--color-text);
    font-weight: 500;
    min-width: 0;
  }

  .ranking-link:hover {
    text-decoration: underline;
  }

  .ranking-count {
    flex-shrink: 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .ranking-count-unit {
    font-size: 0.8rem;
    margin-left: 0.15rem;
  }

  .ranking-empty {
    margin: 0.5rem 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
</style>

